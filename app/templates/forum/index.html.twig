{% extends 'base.html.twig' %}
{% block title %}Community{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-8">

    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-black text-gray-900">Community 🤝</h1>
            <p class="text-sm text-gray-500 mt-0.5">You're not alone in this.</p>
        </div>
        {% if user.forumUsername %}
        <a href="{{ path('app_forum_new') }}"
           class="px-5 py-2.5 bg-gradient-to-r from-brand-600 to-teal-600 text-white rounded-xl font-semibold text-sm hover:opacity-90 transition">
            + New Post
        </a>
        {% else %}
        <a href="{{ path('app_forum_setup') }}"
           class="px-5 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 transition">
            Join to Post
        </a>
        {% endif %}
    </div>

    {# Category tabs #}
    <div class="flex gap-2 mb-6 overflow-x-auto pb-1">
        {% for cat, label in {'all': '🌐 All', 'wins': '🏆 Wins', 'support': '💙 Support', 'general': '💬 General', 'feedback': '📣 Feedback'} %}
        <a href="{{ path('app_forum', {category: cat}) }}"
           class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition
                  {{ category == cat ? 'bg-brand-600 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:border-brand-400' }}">
            {{ label }}
        </a>
        {% endfor %}
    </div>

    {% if posts is empty %}
    <div class="bg-white rounded-2xl border border-gray-100 p-12 text-center">
        <div class="text-4xl mb-3">🌱</div>
        <p class="text-gray-500 font-medium">No posts yet in this category.</p>
        <p class="text-gray-400 text-sm mt-1">Be the first to share something.</p>
        {% if user.forumUsername %}
        <a href="{{ path('app_forum_new', {category: category}) }}"
           class="mt-5 inline-block px-5 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 transition">
            Write a post
        </a>
        {% endif %}
    </div>
    {% else %}
    <div class="space-y-3">
        {% for post in posts %}
        <a href="{{ path('app_forum_post', {id: post.id}) }}"
           class="block bg-white rounded-2xl border border-gray-100 hover:border-brand-200 hover:shadow-sm p-5 transition group">
            <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                        <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full {{ post.categoryColor }}">
                            {{ post.categoryLabel }}
                        </span>
                        {% if post.flagged and app.user.email == admin_email %}
                        <span class="text-xs text-red-400">⚑ flagged</span>
                        {% endif %}
                    </div>
                    <h2 class="font-bold text-gray-900 group-hover:text-brand-700 transition truncate">{{ post.title }}</h2>
                    <p class="text-sm text-gray-500 mt-1 line-clamp-2">{{ post.body|slice(0, 140) }}{% if post.body|length > 140 %}…{% endif %}</p>
                </div>
                <div class="text-right flex-shrink-0 text-xs text-gray-400 space-y-1">
                    <div>{{ post.createdAt|date('M j') }}</div>
                    <div class="flex items-center gap-1 justify-end">
                        <span>💬</span>
                        <span>{{ post.replies|length }}</span>
                    </div>
                </div>
            </div>
            <div class="mt-2 text-xs text-gray-400">
                by <span class="font-medium text-gray-600">{{ post.user.forumUsername ?? 'anonymous' }}</span>
            </div>
        </a>
        {% endfor %}
    </div>
    {% endif %}

</div>
{% endblock %}
