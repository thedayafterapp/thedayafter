{% extends 'base.html.twig' %}
{% block title %}Choose Your Username{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-16">
    <div class="text-center mb-8">
        <a href="{{ path('app_forum') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Community</a>
        <div class="text-4xl mt-4 mb-2">👤</div>
        <h1 class="text-3xl font-black text-gray-900">Choose a Username</h1>
        <p class="text-gray-500 mt-2 text-sm leading-relaxed">
            Your username is public — it's separate from your account name.<br>
            You only set this once.
        </p>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
        {% if error %}
        <div class="mb-5 p-3 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{ error }}</div>
        {% endif %}

        <form method="POST" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">Username</label>
                <input type="text" name="forum_username" required
                       minlength="3" maxlength="30"
                       pattern="[a-zA-Z0-9_]+"
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition font-mono"
                       placeholder="recovery_warrior">
                <p class="text-xs text-gray-400 mt-1.5">3–30 characters. Letters, numbers, underscores only.</p>
            </div>

            <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-xs text-amber-800 leading-relaxed">
                Your real name is never shown in the community. Everything you post appears under this username only.
            </div>

            <button type="submit"
                    class="w-full py-3.5 bg-gradient-to-r from-brand-600 to-teal-600 text-white rounded-xl font-bold text-lg hover:opacity-90 transition">
                Join the Community
            </button>
        </form>
    </div>
</div>
{% endblock %}
