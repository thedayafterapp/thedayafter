{% extends 'base.html.twig' %}
{% block title %}New Post{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-8">

    <div class="mb-6">
        <a href="{{ path('app_forum') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Community</a>
        <h1 class="text-2xl font-black text-gray-900 mt-3">New Post</h1>
    </div>

    {% if error %}
    <div class="mb-5 p-3 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{ error }}</div>
    {% endif %}

    <form method="POST" class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 space-y-5">

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Category</label>
            <div class="grid grid-cols-4 gap-2" x-data="{ cat: '{{ category }}' }">
                {% for val, label in {'general': '💬 General', 'wins': '🏆 Wins', 'support': '💙 Support', 'feedback': '📣 Feedback'} %}
                <label class="cursor-pointer">
                    <input type="radio" name="category" value="{{ val }}" x-model="cat" class="sr-only"
                           {{ category == val ? 'checked' : '' }}>
                    <div :class="cat === '{{ val }}' ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-gray-200 text-gray-600'"
                         class="border-2 rounded-xl p-2.5 text-center text-sm font-medium transition">
                        {{ label }}
                    </div>
                </label>
                {% endfor %}
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Title</label>
            <input type="text" name="title" required maxlength="150"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition"
                   placeholder="What's on your mind?">
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Your message</label>
            <textarea name="body" required rows="5"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition resize-none"
                      placeholder="Share as much or as little as you want. This community gets it."></textarea>
        </div>

        <button type="submit"
                class="w-full py-3 bg-gradient-to-r from-brand-600 to-teal-600 text-white rounded-xl font-bold hover:opacity-90 transition">
            Post to Community
        </button>
    </form>
</div>
{% endblock %}
