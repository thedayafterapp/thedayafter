{% extends 'base.html.twig' %}
{% block title %}Journal{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-10">
    <div class="text-center mb-8">
        <a href="{{ path('app_dashboard') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Dashboard</a>
        <div class="text-4xl mt-4 mb-2">📝</div>
        <h1 class="text-3xl font-black text-gray-900">Your Journal</h1>
        <p class="text-gray-500 mt-1">Writing heals. Every entry earns +30 XP.</p>
    </div>

    {# New entry form #}
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 mb-8"
         x-data="{ mood: '', expanded: false }">
        <h2 class="font-bold text-gray-900 mb-4">New Entry</h2>

        <form method="POST" action="{{ path('app_journal_new') }}" class="space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('new_journal') }}">
            <div>
                <input type="text" name="title" placeholder="Title (optional)"
                       class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition text-gray-800 font-medium">
            </div>

            <div>
                <textarea name="content" required rows="5"
                          class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition resize-none"
                          placeholder="What's on your mind? How are you really feeling? What worked today? What was hard?
CBT prompt: What thought or situation triggered any cravings? What would you tell a friend in your situation?"></textarea>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">How would you describe this entry?</label>
                <div class="flex flex-wrap gap-2">
                    {% for mood in ['grateful', 'determined', 'struggling', 'reflective', 'hopeful', 'proud', 'anxious', 'peaceful'] %}
                    <label class="cursor-pointer">
                        <input type="radio" name="mood" value="{{ mood }}" x-model="mood" class="sr-only">
                        <span :class="mood === '{{ mood }}' ? 'bg-brand-100 text-brand-700 border-brand-400' : 'bg-gray-50 text-gray-600 border-gray-200'"
                              class="block border-2 rounded-full px-3 py-1 text-xs font-medium capitalize cursor-pointer transition">
                            {{ mood|capitalize }}
                        </span>
                    </label>
                    {% endfor %}
                </div>
            </div>

            <button type="submit"
                    class="w-full py-3.5 bg-gradient-to-r from-purple-600 to-brand-600 text-white rounded-2xl font-bold hover:opacity-90 transition">
                Save Entry (+30 XP) →
            </button>
        </form>
    </div>

    {# CBT Prompts #}
    <div class="bg-purple-50 border border-purple-100 rounded-2xl p-5 mb-8">
        <h3 class="font-bold text-purple-900 mb-2">💡 CBT Writing Prompts</h3>
        <ul class="text-sm text-purple-700 space-y-1 list-disc list-inside">
            <li>What triggered cravings today, and what did I do instead?</li>
            <li>What thought distortions did I notice? (All-or-nothing, catastrophizing…)</li>
            <li>What am I grateful for that addiction would take from me?</li>
            <li>What would I tell my best friend if they were in my situation?</li>
            <li>What strength did I show today that I hadn't seen before?</li>
        </ul>
    </div>

    {# Past entries #}
    {% if entries is not empty %}
    <div>
        <h2 class="font-bold text-gray-900 mb-4">Past Entries</h2>
        <div class="space-y-4">
            {% for entry in entries %}
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden"
                 x-data="{ expanded: false, editing: false, mood: '{{ entry.mood }}' }">

                {# View / collapsed header #}
                <div class="p-5 cursor-pointer" @click="!editing && (expanded = !expanded)">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1">
                            <div class="flex items-center gap-3">
                                {% if entry.mood %}
                                <span class="text-xs px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 capitalize">{{ entry.mood }}</span>
                                {% endif %}
                                <span class="text-xs text-gray-400">{{ entry.createdAt|date('F j, Y · g:i a', user.timezone) }}</span>
                            </div>
                            {% if entry.title %}
                            <h3 class="font-bold text-gray-900 mt-1">{{ entry.title }}</h3>
                            {% endif %}
                            <p class="text-gray-600 text-sm mt-1 line-clamp-2" x-show="!expanded && !editing">
                                {{ entry.content|slice(0, 150) }}{% if entry.content|length > 150 %}…{% endif %}
                            </p>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <button type="button" @click.stop="editing = !editing; expanded = true"
                                    class="text-gray-300 hover:text-indigo-400 transition text-sm" title="Edit">✏️</button>
                            <form method="POST" action="{{ path('app_journal_delete', {id: entry.id}) }}"
                                  onsubmit="return confirm('Delete this entry?')" @click.stop>
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_journal_' ~ entry.id) }}">
                                <button type="submit" class="text-gray-300 hover:text-red-400 transition" title="Delete">🗑</button>
                            </form>
                            <svg class="w-4 h-4 text-gray-400 transition-transform"
                                 :class="expanded ? 'rotate-180' : ''"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24" x-show="!editing">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </div>
                </div>

                {# Expanded read view #}
                <div x-show="expanded && !editing" x-cloak class="px-5 pb-5">
                    <div class="border-t border-gray-100 pt-4">
                        <p class="text-gray-700 text-sm whitespace-pre-wrap leading-relaxed">{{ entry.content }}</p>
                    </div>
                </div>

                {# Edit form #}
                <div x-show="editing" x-cloak class="px-5 pb-5">
                    <div class="border-t border-gray-100 pt-4">
                        <form method="POST" action="{{ path('app_journal_edit', {id: entry.id}) }}" class="space-y-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('edit_journal_' ~ entry.id) }}">
                            <input type="text" name="title" value="{{ entry.title }}" placeholder="Title (optional)"
                                   class="w-full px-3 py-2 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 text-sm font-medium">
                            <textarea name="content" required rows="6"
                                      class="w-full px-3 py-2 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 resize-none text-sm">{{ entry.content }}</textarea>
                            <div class="flex flex-wrap gap-2">
                                {% for m in ['grateful', 'determined', 'struggling', 'reflective', 'hopeful', 'proud', 'anxious', 'peaceful'] %}
                                <label class="cursor-pointer">
                                    <input type="radio" name="mood" value="{{ m }}" x-model="mood" class="sr-only">
                                    <span :class="mood === '{{ m }}' ? 'bg-brand-100 text-brand-700 border-brand-400' : 'bg-gray-50 text-gray-600 border-gray-200'"
                                          class="block border-2 rounded-full px-3 py-1 text-xs font-medium capitalize cursor-pointer transition">
                                        {{ m|capitalize }}
                                    </span>
                                </label>
                                {% endfor %}
                            </div>
                            <div class="flex gap-2">
                                <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-xl transition">Save</button>
                                <button type="button" @click="editing = false; expanded = false" class="px-4 py-2 text-sm text-gray-400 hover:text-gray-600 transition">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="text-center py-12 text-gray-400">
        <div class="text-5xl mb-4">📖</div>
        <p class="text-lg">Your journal is empty.</p>
        <p class="text-sm mt-1">Write your first entry above. It doesn't have to be perfect.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
