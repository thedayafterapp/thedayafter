{% extends 'base.html.twig' %}
{% block title %}Create Your Account{% endblock %}

{% block body %}
<div class="min-h-screen gradient-hero flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-lg">
        <div class="text-center mb-8">
            <a href="{{ path('app_home') }}" class="text-white/80 hover:text-white text-sm">← Back to home</a>
            <div class="text-5xl mt-4 mb-3">🌱</div>
            <h1 class="text-3xl font-black text-white">Begin Your Journey</h1>
            <p class="text-white/70 mt-2">This is the most important decision you'll make today.</p>
        </div>

        <div class="bg-white rounded-3xl shadow-2xl p-8">
            {% if error %}<div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">{{ error }}</div>{% endif %}

            <form method="POST" action="{{ path('app_register') }}" class="space-y-5"
                  x-data="registerApp()" x-init="init()">

                {# Hidden timezone field — set by JS #}
                <input type="hidden" name="timezone" x-model="tz">

                <div class="grid sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Your Name</label>
                        <input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition" placeholder="Alex">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
                        <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition" placeholder="you@email.com">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Password <span class="font-normal text-gray-400">(min. 8 characters)</span></label>
                    <input type="password" name="password" required minlength="8" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition" placeholder="Make it strong">
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">What are you working on?</label>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                        <label class="cursor-pointer">
                            <input type="radio" name="addiction_type" value="alcohol" x-model="type" class="sr-only">
                            <div :class="type==='alcohol' ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-gray-200 text-gray-600'"
                                 class="border-2 rounded-xl p-3 text-center transition">
                                <div class="text-2xl mb-1">🍷</div><div class="text-xs font-semibold">Alcohol</div>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="addiction_type" value="cigarettes" x-model="type" class="sr-only">
                            <div :class="type==='cigarettes' ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-gray-200 text-gray-600'"
                                 class="border-2 rounded-xl p-3 text-center transition">
                                <div class="text-2xl mb-1">🚬</div><div class="text-xs font-semibold">Cigarettes</div>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="addiction_type" value="cannabis" x-model="type" class="sr-only">
                            <div :class="type==='cannabis' ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-gray-200 text-gray-600'"
                                 class="border-2 rounded-xl p-3 text-center transition">
                                <div class="text-2xl mb-1">🌿</div><div class="text-xs font-semibold">Cannabis</div>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="addiction_type" value="both" x-model="type" class="sr-only" checked>
                            <div :class="type==='both' ? 'border-brand-500 bg-brand-50 text-brand-700' : 'border-gray-200 text-gray-600'"
                                 class="border-2 rounded-xl p-3 text-center transition">
                                <div class="text-2xl mb-1">💪</div><div class="text-xs font-semibold">Alcohol &amp; Cigarettes</div>
                            </div>
                        </label>
                    </div>
                </div>

                {# Cannabis track #}
                <div x-show="type === 'cannabis'" class="space-y-3 p-4 bg-green-50 border border-green-100 rounded-xl">
                    <p class="text-sm font-semibold text-green-700">🌿 Cannabis Track</p>
                    <div class="grid sm:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Cannabis-free since</label>
                            <input type="datetime-local" name="cannabis_quit_date" :max="nowLocal"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-400 text-sm">
                            <p class="text-xs text-gray-400 mt-1">Leave blank for right now</p>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Daily spend on cannabis</label>
                            <input type="number" name="cannabis_daily_cost" step="0.01" min="0"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-green-400 text-sm"
                                   placeholder="e.g. 15.00">
                        </div>
                    </div>
                </div>

                {# Currency — shown only when a track is selected #}
                <div x-show="type === 'alcohol' || type === 'cigarettes' || type === 'both' || type === 'cannabis'">
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Currency <span class="font-normal text-gray-400">— used to calculate money saved</span></label>
                    <select name="currency" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition">
                        <option value="USD">USD ($)</option>
                        <option value="EUR">EUR (€)</option>
                        <option value="GBP">GBP (£)</option>
                        <option value="CAD">CAD ($)</option>
                        <option value="AUD">AUD ($)</option>
                    </select>
                </div>

                {# Alcohol track #}
                <div x-show="type === 'alcohol' || type === 'both'" class="space-y-3 p-4 bg-red-50 border border-red-100 rounded-xl">
                    <p class="text-sm font-semibold text-red-700">🍷 Alcohol Track</p>
                    <div class="grid sm:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Alcohol-free since</label>
                            <input type="datetime-local" name="alcohol_quit_date" :max="nowLocal"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-red-400 text-sm">
                            <p class="text-xs text-gray-400 mt-1">Leave blank for right now</p>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Daily spend on alcohol</label>
                            <input type="number" name="alcohol_daily_cost" step="0.01" min="0"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-red-400 text-sm"
                                   placeholder="e.g. 20.00">
                        </div>
                    </div>
                </div>

                {# Cigarettes track #}
                <div x-show="type === 'cigarettes' || type === 'both'" class="space-y-3 p-4 bg-amber-50 border border-amber-100 rounded-xl">
                    <p class="text-sm font-semibold text-amber-700">🚬 Cigarettes Track</p>
                    <div class="grid sm:grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Smoke-free since</label>
                            <input type="datetime-local" name="cigarettes_quit_date" :max="nowLocal"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-red-400 text-sm">
                            <p class="text-xs text-gray-400 mt-1">Leave blank for right now</p>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-1">Daily spend on cigarettes</label>
                            <input type="number" name="cigarettes_daily_cost" step="0.01" min="0"
                                   class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-red-400 text-sm"
                                   placeholder="e.g. 10.00">
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                        Why are you doing this? <span class="font-normal text-gray-400">(optional — we'll remind you when it's hard)</span>
                    </label>
                    <textarea name="motivation" rows="2"
                              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 resize-none text-sm"
                              placeholder="For my kids. For my health. Because I deserve better. Because I'm tired of losing…"></textarea>
                </div>

                <div>
                    <div>
                        <div class="flex items-center justify-between mb-1.5">
                            <label class="block text-sm font-semibold text-gray-700">Timezone</label>
                            <button type="button" @click="detectTz()"
                                    class="text-xs text-brand-600 hover:underline">📍 Auto-detect</button>
                        </div>
                        <select x-ref="tzSel" @change="tz = $event.target.value"
                                class="w-full px-3 py-2 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-brand-400 transition text-sm">
                            {% set timezones = {
                                'UTC': 'UTC',
                                'America/New_York': 'America — New York (ET)',
                                'America/Chicago': 'America — Chicago (CT)',
                                'America/Denver': 'America — Denver (MT)',
                                'America/Los_Angeles': 'America — Los Angeles (PT)',
                                'America/Phoenix': 'America — Phoenix (MST)',
                                'America/Anchorage': 'America — Anchorage (AKT)',
                                'America/Honolulu': 'America — Honolulu (HST)',
                                'America/Toronto': 'America — Toronto (ET)',
                                'America/Vancouver': 'America — Vancouver (PT)',
                                'America/Mexico_City': 'America — Mexico City (CST)',
                                'America/Sao_Paulo': 'America — São Paulo (BRT)',
                                'America/Argentina/Buenos_Aires': 'America — Buenos Aires (ART)',
                                'America/Bogota': 'America — Bogotá (COT)',
                                'America/Lima': 'America — Lima (PET)',
                                'Europe/London': 'Europe — London (GMT/BST)',
                                'Europe/Lisbon': 'Europe — Lisbon (WET)',
                                'Europe/Paris': 'Europe — Paris (CET)',
                                'Europe/Berlin': 'Europe — Berlin (CET)',
                                'Europe/Rome': 'Europe — Rome (CET)',
                                'Europe/Madrid': 'Europe — Madrid (CET)',
                                'Europe/Amsterdam': 'Europe — Amsterdam (CET)',
                                'Europe/Stockholm': 'Europe — Stockholm (CET)',
                                'Europe/Warsaw': 'Europe — Warsaw (CET)',
                                'Europe/Zurich': 'Europe — Zurich (CET)',
                                'Europe/Athens': 'Europe — Athens (EET)',
                                'Europe/Helsinki': 'Europe — Helsinki (EET)',
                                'Europe/Istanbul': 'Europe — Istanbul (TRT)',
                                'Europe/Moscow': 'Europe — Moscow (MSK)',
                                'Europe/Kiev': 'Europe — Kyiv (EET)',
                                'Asia/Dubai': 'Asia — Dubai (GST)',
                                'Asia/Kolkata': 'Asia — Kolkata (IST)',
                                'Asia/Dhaka': 'Asia — Dhaka (BST)',
                                'Asia/Bangkok': 'Asia — Bangkok (ICT)',
                                'Asia/Singapore': 'Asia — Singapore (SGT)',
                                'Asia/Hong_Kong': 'Asia — Hong Kong (HKT)',
                                'Asia/Shanghai': 'Asia — Shanghai (CST)',
                                'Asia/Tokyo': 'Asia — Tokyo (JST)',
                                'Asia/Seoul': 'Asia — Seoul (KST)',
                                'Asia/Jakarta': 'Asia — Jakarta (WIB)',
                                'Australia/Perth': 'Australia — Perth (AWST)',
                                'Australia/Brisbane': 'Australia — Brisbane (AEST)',
                                'Australia/Sydney': 'Australia — Sydney (AEDT)',
                                'Australia/Melbourne': 'Australia — Melbourne (AEDT)',
                                'Pacific/Auckland': 'Pacific — Auckland (NZST)',
                                'Africa/Cairo': 'Africa — Cairo (EET)',
                                'Africa/Johannesburg': 'Africa — Johannesburg (SAST)',
                                'Africa/Lagos': 'Africa — Lagos (WAT)'
                            } %}
                            {% for val, label in timezones %}
                            <option value="{{ val }}">{{ label }}</option>
                            {% endfor %}
                        </select>
                        <p class="text-xs text-gray-400 mt-1">
                            Current: <span class="font-medium text-gray-600" x-text="tz"></span>
                        </p>
                    </div>
                </div>

                <button type="submit" class="w-full py-4 bg-gradient-to-r from-brand-600 to-teal-600 text-white rounded-xl font-bold text-lg hover:opacity-90 transition shadow-md">
                    Start My Journey →
                </button>
            </form>

            <p class="mt-6 text-center text-gray-500 text-sm">
                Already have an account? <a href="{{ path('app_login') }}" class="text-brand-600 font-semibold hover:underline">Sign in</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
function registerApp() {
    return {
        type: 'both',
        tz: 'UTC',
        nowLocal: '',
        init() {
            const now = new Date();
            const pad = n => String(n).padStart(2, '0');
            this.nowLocal = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;
        },
        detectTz() {
            try {
                const detected = Intl.DateTimeFormat().resolvedOptions().timeZone;
                if (!detected) return;
                this.tz = detected;
                const sel = this.$refs.tzSel;
                let opt = Array.from(sel.options).find(o => o.value === detected);
                if (!opt) {
                    opt = new Option(detected, detected);
                    sel.prepend(opt);
                }
                sel.value = detected;
            } catch(e) {}
        }
    };
}
</script>
{% endblock %}
