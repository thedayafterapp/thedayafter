{% extends 'base.html.twig' %}
{% block title %}Achievements{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-10">
    <div class="text-center mb-10">
        <a href="{{ path('app_dashboard') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Dashboard</a>
        <div class="text-4xl mt-4 mb-2">🏆</div>
        <h1 class="text-3xl font-black text-gray-900">Achievements</h1>
        <p class="text-gray-500 mt-1">{{ earned|length }} of {{ achievements|length }} earned</p>

        <div class="mt-4 inline-flex items-center gap-3 bg-amber-50 border border-amber-200 rounded-full px-5 py-2 relative group cursor-default">
            <span class="text-amber-500 text-xl">⚡</span>
            <span class="font-bold text-amber-700">{{ user.totalXp }} Total XP</span>
            <span class="text-amber-500">·</span>
            <span class="text-amber-700">Level {{ user.level }}: {{ user.levelName }}</span>
            <span class="text-amber-400 text-xs">ⓘ</span>
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 bg-gray-900 text-white text-xs rounded-xl px-3 py-2.5 leading-relaxed opacity-0 group-hover:opacity-100 transition pointer-events-none z-20">
                <p class="font-bold mb-1">Two separate systems</p>
                <p class="text-white/70"><span class="text-amber-400">⚡ XP</span> — earned by check-ins, surviving cravings, journaling.</p>
                <p class="text-white/70 mt-1"><span class="text-teal-400">Level</span> — based on days sober: 1d→L2 · 7d→L3 · 30d→L4 · 90d→L5 · 180d→L6 · 365d→L7</p>
                <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900"></div>
            </div>
        </div>
        {% if earned|length > 0 %}
        <form method="POST" action="{{ path('app_achievements_reset') }}"
              class="mt-4"
              onsubmit="return confirm('Reset all achievements? This cannot be undone.')">
            <input type="hidden" name="_token" value="{{ csrf_token('reset_achievements') }}">
            <button type="submit" class="text-xs text-gray-400 hover:text-red-400 transition">
                Reset all achievements
            </button>
        </form>
        {% endif %}
    </div>


    {# Achievements by category #}
    {% set categories = {
        'streak':  { label: '🔥 Streak Milestones', desc: 'Keep going — every day is a new record' },
        'craving': { label: '🌊 Craving Survivor', desc: 'Every wave you surf makes you stronger' },
        'checkin': { label: '📊 Daily Check-In', desc: 'Consistency transforms lives' },
        'journal': { label: '📝 Journal', desc: 'Self-reflection is a superpower' },
        'money':   { label: '💰 Money Saved', desc: 'Your wallet is also healing (in ' ~ user.currency ~ ')' },
    } %}

    {% for catKey, catMeta in categories %}
    {% set catAchievements = achievements|filter(a => a.category == catKey) %}
    {% if catAchievements|length > 0 %}
    <div class="mb-8">
        <div class="mb-4">
            <h2 class="text-xl font-black text-gray-900">{{ catMeta.label }}</h2>
            <p class="text-sm text-gray-500">{{ catMeta.desc }}</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for achievement in catAchievements %}
            {% set isEarned = achievement.slug in earned|keys %}
            <div class="bg-white rounded-2xl border-2 p-5 transition
                        {{ isEarned ? 'border-amber-300 shadow-md' : 'border-gray-100 opacity-60' }}">
                <div class="flex items-start gap-3">
                    <div class="text-3xl {{ isEarned ? '' : 'grayscale' }}">{{ achievement.icon }}</div>
                    <div class="flex-1">
                        <div class="font-bold text-gray-900 text-sm">{{ achievement.name }}</div>
                        <div class="text-xs text-gray-500 mt-0.5 leading-snug">{{ achievement.description }}</div>
                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-xs font-bold text-amber-600">+{{ achievement.xpReward }} XP</span>
                            {% if isEarned %}
                            <span class="text-xs text-teal-600 font-medium">
                                Earned {{ earned[achievement.slug]|date('M j, Y') }}
                            </span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% if isEarned %}
                <div class="mt-3 flex items-center gap-1.5 text-teal-600 text-xs font-semibold">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    Achieved!
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}
    {% endfor %}

</div>
{% endblock %}
