        get today() {
            const d = new Date(), p = n => String(n).padStart(2,'0');
            return `${d.getFullYear()}-${p(d.getMonth()+1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`;
        },

        get setupReady() {
            if (this.setupAddiction === 'alcohol')  return !!this.setupAlcoholDate;
            if (this.setupAddiction === 'smoking')  return !!this.setupSmokingDate;
            if (this.setupAddiction === 'cannabis') return !!this.setupCannabisDate;
            if (this.setupAddiction === 'both')     return !!this.setupAlcoholDate && !!this.setupSmokingDate;
            return false;
        },

        init() {
            const t = this.today;
            this.setupAlcoholDate  = t;
            this.setupSmokingDate  = t;
            this.setupCannabisDate = t;

            const raw = localStorage.getItem('tda_demo');
            if (raw) {
                try {
                    const d = JSON.parse(raw);
                    this.name      = d.name || '';
                    this.addiction = d.addiction || 'alcohol';
                    this.dates     = Object.assign({ alcohol: null, smoking: null, cannabis: null }, d.dates || {});
                    this.moods     = d.moods || [];
                    this.currency  = d.currency || '$';
                    this.costs     = Object.assign({ alcohol: 0, smoking: 0, cannabis: 0 }, d.costs || {});
                    this.ready     = true;
                } catch(e) { localStorage.removeItem('tda_demo'); }
            }
        },

        persist() {
            localStorage.setItem('tda_demo', JSON.stringify({
                name: this.name, addiction: this.addiction,
                dates: this.dates, moods: this.moods,
                currency: this.currency, costs: this.costs,
            }));
        },

        startDemo() {
            if (!this.setupReady) return;
            this.name      = '';
            this.addiction = this.setupAddiction;
            this.dates = {
                alcohol:  this.setupAlcoholDate  ? new Date(this.setupAlcoholDate)  : null,
                smoking:  this.setupSmokingDate  ? new Date(this.setupSmokingDate)  : null,
                cannabis: this.setupCannabisDate ? new Date(this.setupCannabisDate) : null,
            };
            this.moods = [];
            this.currency = this.setupCurrency;
            this.costs = {
                alcohol:  parseFloat(this.setupAlcoholCost)  || 0,
                smoking:  parseFloat(this.setupSmokingCost)  || 0,
                cannabis: parseFloat(this.setupCannabisCost) || 0,
            };
            this.persist();
            this.ready = true;
            this.$nextTick(() => window.scrollTo(0, 0));
        },

        openEdit() {
            const fmt = d => {
                if (!d) return this.today;
                const dt = new Date(d);
                const p = n => String(n).padStart(2, '0');
                return `${dt.getFullYear()}-${p(dt.getMonth()+1)}-${p(dt.getDate())}T${p(dt.getHours())}:${p(dt.getMinutes())}`;
            };
            this.editAddiction    = this.addiction;
            this.editAlcoholDate  = fmt(this.dates.alcohol);
            this.editSmokingDate  = fmt(this.dates.smoking);
            this.editCannabisDate = fmt(this.dates.cannabis);
            this.editCurrency     = this.currency;
            this.editAlcoholCost  = this.costs.alcohol  || '';
            this.editSmokingCost  = this.costs.smoking  || '';
            this.editCannabisCost = this.costs.cannabis || '';
            this.editOpen = true;
        },

        saveEdit() {
            this.addiction = this.editAddiction;
            this.dates = {
                alcohol:  this.editAlcoholDate  ? new Date(this.editAlcoholDate)  : null,
                smoking:  this.editSmokingDate  ? new Date(this.editSmokingDate)  : null,
                cannabis: this.editCannabisDate ? new Date(this.editCannabisDate) : null,
            };
            this.currency = this.editCurrency;
            this.costs = {
                alcohol:  parseFloat(this.editAlcoholCost)  || 0,
                smoking:  parseFloat(this.editSmokingCost)  || 0,
                cannabis: parseFloat(this.editCannabisCost) || 0,
            };
            this.persist();
            this.editOpen = false;
        },

        get moodEmoji() {
            const m = parseInt(this.moodScore);
            if (m>=9) return '😄'; if (m>=7) return '😊'; if (m>=5) return '😐'; if (m>=3) return '😔'; return '😢';
        },

        toggleSOS() {
            this.sosOpen = !this.sosOpen;
            if (this.sosOpen) this.$nextTick(() => document.getElementById('demo-sos-block').scrollIntoView({behavior:'smooth', block:'nearest'}));
        },

        submitMood() {
            this.moods = [...this.moods, { date: new Date().toISOString(), score: parseInt(this.moodScore), note: this.moodNote }];
            this.moodNote = '';
            this.moodOpen = false;
            this.moodSaved = true;
            this.persist();
            setTimeout(() => this.moodSaved = false, 3000);
        },

        get alcoholDays() {
            if (!this.dates.alcohol) return 0;
            return Math.max(0, Math.floor((Date.now() - new Date(this.dates.alcohol).getTime()) / 86400000));
        },
        get smokingDays() {
            if (!this.dates.smoking) return 0;
            return Math.max(0, Math.floor((Date.now() - new Date(this.dates.smoking).getTime()) / 86400000));
        },
        get alcoholDateFormatted() {
            if (!this.dates.alcohol) return '';
            return new Date(this.dates.alcohol).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });
        },
        get smokingDateFormatted() {
            if (!this.dates.smoking) return '';
            return new Date(this.dates.smoking).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });
        },

        get moneySaved() {
            const a = parseFloat(this.costs.alcohol)  || 0;
            const s = parseFloat(this.costs.smoking)  || 0;
            const c = parseFloat(this.costs.cannabis) || 0;
            if (this.addiction === 'both')     return this.alcoholDays * a + this.smokingDays * s;
            if (this.addiction === 'alcohol')  return this.days * a;
            if (this.addiction === 'smoking')  return this.days * s;
            if (this.addiction === 'cannabis') return this.days * c;
            return 0;
        },

        get primaryDate() {
            if (this.addiction === 'alcohol')  return this.dates.alcohol;
            if (this.addiction === 'smoking')  return this.dates.smoking;
            if (this.addiction === 'cannabis') return this.dates.cannabis;
            // both: use earlier of alcohol/smoking
            const a = this.dates.alcohol  ? new Date(this.dates.alcohol).getTime()  : Infinity;
            const s = this.dates.smoking  ? new Date(this.dates.smoking).getTime()  : Infinity;
            const earliest = Math.min(a, s);
            return earliest === Infinity ? null : new Date(earliest);
        },

        get days() {
            if (!this.primaryDate) return 0;
            return Math.max(0, Math.floor((Date.now() - new Date(this.primaryDate).getTime()) / 86400000));
        },

        get addictionLabel() {
            return { alcohol:'🍺 Alcohol-free', smoking:'🚬 Smoke-free', cannabis:'🌿 Cannabis-free', both:'🍺🚬 Alcohol & Smoke-free' }[this.addiction] || '';
        },

        get primaryDateFormatted() {
            const d = this.primaryDate;
            if (!d) return '';
            return new Date(d).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });
        },

        get level() {
            const d = this.days;
            if (d>=365) return 7; if (d>=180) return 6; if (d>=90) return 5;
            if (d>=30)  return 4; if (d>=7)   return 3; if (d>=1)  return 2;
            return 1;
        },

        get levelName() {
            return ['Awakening','Day One Hero','First Week','Building Strength','Deep Healing','Transformation','Beacon of Light'][this.level-1];
        },

        get registerUrl() {
            const d = this.primaryDate;
            const typeMap = { alcohol:'alcohol', smoking:'cigarettes', cannabis:'cannabis', both:'both' };
            const params = new URLSearchParams({ addiction: typeMap[this.addiction]||'alcohol' });
            if (d) {
                const dt = new Date(d), p = n => String(n).padStart(2,'0');
                params.set('quit_date', `${dt.getFullYear()}-${p(dt.getMonth()+1)}-${p(dt.getDate())}`);
            }
            if (this.name) params.set('name', this.name);
            return '/register?' + params.toString();
        },

        get healingTitle() {
            return { alcohol:'Alcohol-Free — Body Healing', smoking:'Smoke-Free — Body Healing', cannabis:'Cannabis-Free — Body Healing', both:'Alcohol-Free — Body Healing' }[this.addiction] || 'Body Healing';
        },

        get healingMilestones() {
            const h = this.days * 24;
            const alcohol = [
                { label:'24 hours',  desc:'Blood sugar begins to stabilize',                  achieved: h>=24   },
                { label:'72 hours',  desc:'Alcohol fully cleared from your system',            achieved: h>=72   },
                { label:'1 week',    desc:'Sleep quality improves, anxiety reduces',           achieved: h>=168  },
                { label:'2 weeks',   desc:'Liver begins active regeneration',                  achieved: h>=336  },
                { label:'1 month',   desc:'Skin clearer, energy returning, brain fog lifting', achieved: h>=720  },
                { label:'3 months',  desc:'Memory and cognition sharpen significantly',        achieved: h>=2160 },
                { label:'6 months',  desc:'Liver function mostly restored',                    achieved: h>=4320 },
                { label:'1 year',    desc:'Cancer and heart disease risk significantly reduced', achieved: h>=8760 },
            ];
            const smoking = [
                { label:'20 minutes', desc:'Heart rate and blood pressure drop',               achieved: this.days>=0 && h*60>=20 },
                { label:'8 hours',    desc:'Carbon monoxide in blood drops by half',           achieved: h>=8    },
                { label:'24 hours',   desc:'Heart attack risk begins to decrease',             achieved: h>=24   },
                { label:'48 hours',   desc:'Smell and taste start to return',                  achieved: h>=48   },
                { label:'2 weeks',    desc:'Circulation improves, walking feels easier',       achieved: h>=336  },
                { label:'1 month',    desc:'Coughing and shortness of breath reduce',          achieved: h>=720  },
                { label:'3 months',   desc:'Lung function increases up to 30%',                achieved: h>=2160 },
                { label:'1 year',     desc:'Risk of coronary heart disease halved',            achieved: h>=8760 },
            ];
            const cannabis = [
                { label:'24 hours',  desc:'THC levels in blood begin to drop',                achieved: h>=24   },
                { label:'72 hours',  desc:'Sleep patterns start to normalize',                 achieved: h>=72   },
                { label:'1 week',    desc:'Anxiety and irritability begin to ease',            achieved: h>=168  },
                { label:'2 weeks',   desc:'Appetite and mood stabilize',                       achieved: h>=336  },
                { label:'1 month',   desc:'Memory and focus noticeably sharper',               achieved: h>=720  },
                { label:'3 months',  desc:'Lung function improves (if smoked)',                achieved: h>=2160 },
                { label:'6 months',  desc:'Motivation and emotional balance restored',         achieved: h>=4320 },
                { label:'1 year',    desc:'Full cognitive recovery for most people',           achieved: h>=8760 },
            ];
            if (this.addiction==='smoking')  return smoking;
            if (this.addiction==='cannabis') return cannabis;
            return alcohol;
        },

        deleteAll() {
            localStorage.removeItem('tda_demo');
            localStorage.removeItem('tda_demo_banner');
            this.ready = false;
            this.moods = [];
            this.dates = { alcohol: null, smoking: null, cannabis: null };
            const t = this.today;
            this.setupAlcoholDate = t;
            this.setupSmokingDate = t;
            this.setupCannabisDate = t;
            this.setupAddiction = 'alcohol';
            this.currency = '$';
            this.costs = { alcohol: 0, smoking: 0, cannabis: 0 };
            this.setupCurrency = '$';
            this.setupAlcoholCost = '';
            this.setupSmokingCost = '';
            this.setupCannabisCost = '';
        },

        renderMoodChart(moods) {
            const svg  = document.getElementById('demo-mood-svg');
            const wrap = document.getElementById('demo-mood-chart-wrap');
            if (!svg || !wrap) return;

            // Register resize observer once so chart redraws on layout changes
            if (!this._chartObserver && window.ResizeObserver) {
                this._chartObserver = new ResizeObserver(() => this.renderMoodChart(this.moods));
                this._chartObserver.observe(wrap);
            }
            // Expose redraw for fullscreen expand/collapse transitions
            window._demoMoodChart = () => this.renderMoodChart(this.moods);

            svg.innerHTML = '';
            if (!moods || moods.length === 0) return;

            // Format ISO date → "Day, Mon D · H:MM am/pm"
            function fmtDate(iso) {
                const d = new Date(iso);
                const days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
                const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                const h = d.getHours(), m = d.getMinutes();
                const ampm = h >= 12 ? 'pm' : 'am';
                const hr = h % 12 || 12;
                const min = m > 0 ? `:${String(m).padStart(2,'0')}` : '';
                return `${days[d.getDay()]}, ${months[d.getMonth()]} ${d.getDate()} · ${hr}${min} ${ampm}`;
            }

            const DATA = moods.slice()
                .sort((a, b) => new Date(a.date) - new Date(b.date))
                .map(m => ({ mood: m.score, date: fmtDate(m.date) }));

            function moodColor(m) {
                if (m >= 8) return '#22c55e';
                if (m >= 6) return '#84cc16';
                if (m >= 4) return '#f59e0b';
                return '#ef4444';
            }

            const W = wrap.clientWidth;
            const H = wrap.clientHeight;
            const pad = { top: 10, right: 17, bottom: 42, left: 25 };
            const cW = W - pad.left - pad.right;
            const cH = H - pad.top - pad.bottom;
            if (cW <= 0 || cH <= 0) return;

            const n = DATA.length;
            const yInset = 10;
            const pts = DATA.map((d, i) => ({
                x: pad.left + (n > 1 ? i / (n - 1) : 0.5) * cW,
                y: pad.top + yInset + (10 - d.mood) / 9 * (cH - yInset * 2),
                mood: d.mood, date: d.date
            }));

            const ns = 'http://www.w3.org/2000/svg';
            function el(tag, attrs, parent) {
                const e = document.createElementNS(ns, tag);
                Object.entries(attrs || {}).forEach(([k, v]) => e.setAttribute(k, v));
                if (parent) parent.appendChild(e);
                return e;
            }

            svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
            const defs = el('defs', {}, svg);

            // Area fill gradient
            const areaGrad = el('linearGradient', { id:'dmc-area', x1:'0', y1:'0', x2:'0', y2:'1' }, defs);
            el('stop', { offset:'0%',   'stop-color':'#6366f1', 'stop-opacity':'0.25' }, areaGrad);
            el('stop', { offset:'100%', 'stop-color':'#6366f1', 'stop-opacity':'0.01' }, areaGrad);

            // Line gradient
            const lineGrad = el('linearGradient', { id:'dmc-line', x1:'0', y1:'0', x2:'1', y2:'0' }, defs);
            el('stop', { offset:'0%',   'stop-color':'#a5b4fc' }, lineGrad);
            el('stop', { offset:'100%', 'stop-color':'#6366f1' }, lineGrad);

            // Dot glow filter
            const filter = el('filter', { id:'dmc-glow', x:'-50%', y:'-50%', width:'200%', height:'200%' }, defs);
            el('feGaussianBlur', { stdDeviation:'3', result:'blur' }, filter);
            const merge = el('feMerge', {}, filter);
            el('feMergeNode', { in:'blur' }, merge);
            el('feMergeNode', { in:'SourceGraphic' }, merge);

            // Clip path
            const clip = el('clipPath', { id:'dmc-clip' }, defs);
            el('rect', { x: pad.left, y: pad.top, width: cW, height: cH }, clip);

            // Mood zone bands
            [
                { from: 7, to: 10, color: '#f0fdf4' },
                { from: 4, to: 7,  color: '#fefce8' },
                { from: 1, to: 4,  color: '#fff1f2' },
            ].forEach(z => {
                const y1 = pad.top + (10 - z.to)   / 9 * cH;
                const y2 = pad.top + (10 - z.from) / 9 * cH;
                el('rect', { x: pad.left, y: y1, width: cW, height: y2 - y1,
                             fill: z.color, 'clip-path': 'url(#dmc-clip)' }, svg);
            });

            // Grid lines + Y labels
            [2, 4, 6, 8, 10].forEach(v => {
                const gy = pad.top + (10 - v) / 9 * cH;
                el('line', { x1: pad.left, y1: gy, x2: pad.left + cW, y2: gy,
                             stroke: '#e5e7eb', 'stroke-width': '1',
                             'stroke-dasharray': v % 4 === 0 ? '0' : '3 3' }, svg);
                const t = el('text', { x: pad.left - 7, y: gy + 3.5, 'text-anchor': 'end',
                                       'font-size': '11', fill: '#6b7280',
                                       'font-family': 'inherit', 'font-weight': '500' }, svg);
                t.textContent = v;
            });

            // Bottom border
            el('line', { x1: pad.left, y1: pad.top + cH, x2: pad.left + cW, y2: pad.top + cH,
                         stroke: '#e5e7eb', 'stroke-width': '1' }, svg);

            // X axis labels — spaced so they don't collide
            let prevLabelX = -Infinity, prevDatePart = '';
            const MIN_SPACING = 72;
            DATA.forEach((d, i) => {
                const x = pts[i].x;
                if (x - prevLabelX < MIN_SPACING) return;
                prevLabelX = x;
                const [datePart, timePart] = d.date.split(' · ');
                const sameDate = datePart === prevDatePart;
                prevDatePart = datePart;
                el('line', { x1: x, y1: pad.top, x2: x, y2: pad.top + cH,
                             stroke: '#f3f4f6', 'stroke-width': '1' }, svg);
                if (!sameDate) {
                    const tDate = el('text', { x, y: pad.top + cH + 16, 'text-anchor': 'middle',
                                               'font-size': '11', fill: '#6b7280',
                                               'font-family': 'inherit', 'font-weight': '600' }, svg);
                    tDate.textContent = datePart;
                }
                const tTime = el('text', { x, y: sameDate ? pad.top + cH + 16 : pad.top + cH + 30,
                                           'text-anchor': 'middle', 'font-size': '10',
                                           fill: '#9ca3af', 'font-family': 'inherit' }, svg);
                tTime.textContent = timePart;
            });

            if (n === 1) {
                el('circle', { cx: pts[0].x, cy: pts[0].y, r: '5',
                               fill: moodColor(pts[0].mood), stroke: 'white', 'stroke-width': '2' }, svg);
                return;
            }

            // Smooth cubic bezier via Catmull-Rom → Bezier conversion
            function smoothPath(points) {
                const t = 0.35;
                let d = `M ${points[0].x.toFixed(1)} ${points[0].y.toFixed(1)}`;
                for (let i = 0; i < points.length - 1; i++) {
                    const p0 = points[Math.max(0, i - 1)];
                    const p1 = points[i];
                    const p2 = points[i + 1];
                    const p3 = points[Math.min(points.length - 1, i + 2)];
                    const clampY = y => Math.max(pad.top, Math.min(pad.top + cH, y));
                    const cp1x = p1.x + (p2.x - p0.x) * t;
                    const cp1y = clampY(p1.y + (p2.y - p0.y) * t);
                    const cp2x = p2.x - (p3.x - p1.x) * t;
                    const cp2y = clampY(p2.y - (p3.y - p1.y) * t);
                    d += ` C ${cp1x.toFixed(1)} ${cp1y.toFixed(1)}, ${cp2x.toFixed(1)} ${cp2y.toFixed(1)}, ${p2.x.toFixed(1)} ${p2.y.toFixed(1)}`;
                }
                return d;
            }

            const pathD = smoothPath(pts);
            const first = pts[0], last = pts[pts.length - 1];
            const baseY = pad.top + cH;
            const areaD = pathD + ` L ${last.x} ${baseY} L ${first.x} ${baseY} Z`;

            el('path', { d: areaD, fill: 'url(#dmc-area)', 'clip-path': 'url(#dmc-clip)' }, svg);
            el('path', { d: pathD, fill: 'none', stroke: 'url(#dmc-line)',
                         'stroke-width': '2.5', 'stroke-linecap': 'round', 'stroke-linejoin': 'round',
                         'clip-path': 'url(#dmc-clip)' }, svg);

            // Interactive dots
            const tip     = document.getElementById('demo-mood-tip');
            const tipDate = document.getElementById('demo-mood-tip-date');
            const tipMood = document.getElementById('demo-mood-tip-mood');
            let activeDot = null;

            function showTip(p, x, y) {
                tipDate.textContent = p.date;
                tipMood.textContent = 'Mood ' + p.mood + ' / 10';
                tip.style.left = (x + 14) + 'px';
                tip.style.top  = (y - 52) + 'px';
                tip.classList.remove('hidden');
            }
            function hideTip() { tip.classList.add('hidden'); }

            pts.forEach(p => {
                const color   = moodColor(p.mood);
                const halo    = el('circle', { cx: p.x, cy: p.y, r: '8',   fill: color, opacity: '0' }, svg);
                const dot     = el('circle', { cx: p.x, cy: p.y, r: '4.5', fill: color,
                                               stroke: 'white', 'stroke-width': '2', style: 'cursor:pointer' }, svg);
                const hitArea = el('circle', { cx: p.x, cy: p.y, r: '18',  fill: 'transparent', style: 'cursor:pointer' }, svg);

                function activate(x, y) {
                    halo.setAttribute('opacity', '0.25');
                    halo.setAttribute('r', '10');
                    showTip(p, x, y);
                }
                function deactivate() {
                    halo.setAttribute('opacity', '0');
                    halo.setAttribute('r', '8');
                    hideTip();
                }

                hitArea.addEventListener('mouseenter', e => activate(e.clientX, e.clientY));
                hitArea.addEventListener('mousemove',  e => { tip.style.left = (e.clientX + 14) + 'px'; tip.style.top = (e.clientY - 52) + 'px'; });
                hitArea.addEventListener('mouseleave', () => deactivate());
                hitArea.addEventListener('touchstart', e => {
                    e.preventDefault();
                    if (activeDot && activeDot !== hitArea) activeDot._deactivate();
                    activeDot = hitArea;
                    hitArea._deactivate = deactivate;
                    const t = e.touches[0];
                    activate(t.clientX, t.clientY);
                }, { passive: false });
                hitArea.addEventListener('touchend', e => {
                    e.preventDefault();
                    deactivate();
                }, { passive: false });
            });
        },

        lockedBadges() {
            const d = this.days;
            return [
                { icon:'🌱', name:'First Step',     desc:'Day 1 clean',        earned: d>=1  },
                { icon:'🌿', name:'One Week',       desc:'7 days clean',       earned: d>=7  },
                { icon:'💪', name:'One Month',      desc:'30 days clean',      earned: d>=30 },
                { icon:'📝', name:'Journal Writer', desc:'Write a journal',    earned: false },
                { icon:'🧘', name:'Craving Hero',   desc:'Survive a craving',  earned: false },
                { icon:'🔥', name:'90 Days',        desc:'3 months clean',     earned: d>=90 },
            ];
        },
    };
}

document.addEventListener('alpine:init', () => {
    Alpine.store('demoChart', {
        expanded: false,
        toggle() { this.expanded ? this.collapse() : this.expand(); },
        expand() {
            this.expanded = true;
            document.body.style.overflow = 'hidden';
            setTimeout(() => window._demoMoodChart && window._demoMoodChart(), 50);
        },
        collapse() {
            this.expanded = false;
            document.body.style.overflow = '';
            setTimeout(() => window._demoMoodChart && window._demoMoodChart(), 50);
        }
    });
});

function breathingExercise() {
    return {
        breathing: false, breatheCount: 4, breathePhase: 'Press Start',
        breatheScale: 1, breatheOpacity: 0.7, _timer: null,
        toggleBreathing() {
            this.breathing = !this.breathing;
            if (this.breathing) this.runCycle();
            else { clearTimeout(this._timer); this.breathePhase='Press Start'; this.breatheCount=4; this.breatheScale=1; this.breatheOpacity=0.7; }
        },
        runCycle() { this.runPhase('Breathe in...', 4, 1.3, 1); },
        runPhase(label, secs, scale, opacity) {
            this.breathePhase=label; this.breatheScale=scale; this.breatheOpacity=opacity;
            let count=secs; this.breatheCount=count;
            const tick = () => {
                count--; this.breatheCount=count;
                if (count>0) { this._timer=setTimeout(tick,1000); }
                else {
                    if (!this.breathing) return;
                    if (label==='Breathe in...')  this.runPhase('Hold...',7,1.3,0.9);
                    else if (label==='Hold...')   this.runPhase('Breathe out...',8,0.8,0.5);
                    else                          this.runCycle();
                }
            };
            this._timer=setTimeout(tick,1000);
        },
    };
}
</script>

</body>
