<!DOCTYPE html>
<html lang="en" class="h-full overflow-x-hidden" style="scroll-behavior: smooth;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Try TheDayAfter — No Sign-Up Needed</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: { brand: {
                50:'#f0fdf9',100:'#ccfbef',200:'#99f6e0',300:'#5eead4',
                400:'#2dd4bf',500:'#14b8a6',600:'#0d9488',700:'#0f766e',
                800:'#115e59',900:'#134e4a'
            }}}}
        }
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        .gradient-hero { background: linear-gradient(135deg, #0f766e 0%, #1d4ed8 50%, #7c3aed 100%); }
        @keyframes floatA { 0%,100%{transform:translate(0,0)} 33%{transform:translate(20px,-30px)} 66%{transform:translate(-15px,15px)} }
        @keyframes floatB { 0%,100%{transform:translate(0,0)} 40%{transform:translate(-25px,20px)} 70%{transform:translate(15px,-25px)} }
        .breathe-scale { transition: transform 1s ease-in-out, opacity 1s ease-in-out; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 overflow-x-hidden" x-data="demoApp()" x-init="init()">

{# ── Header ── #}
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2 text-brand-700 font-bold text-lg"><span class="text-xl">🌿</span> TheDayAfter</a>
        <div class="flex items-center gap-2">
            <a href="/login" class="text-sm text-gray-500 hover:text-gray-800 px-3 py-1.5">Sign in</a>
            <a :href="registerUrl" class="px-4 py-1.5 bg-brand-600 hover:bg-brand-700 text-white rounded-lg text-sm font-semibold transition">Sign up free</a>
        </div>
    </div>
</header>

{# ══ SETUP SCREEN ══ #}
<div x-show="!ready" x-cloak class="gradient-hero min-h-screen flex items-center justify-center px-4 pt-14">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-20 right-10 w-48 h-48 rounded-full bg-white/5" style="animation:floatA 14s ease-in-out infinite"></div>
        <div class="absolute bottom-20 -left-10 w-56 h-56 rounded-full bg-white/5" style="animation:floatB 18s ease-in-out infinite"></div>
    </div>
    <div class="relative z-10 w-full max-w-md">
        <div class="text-center mb-8">
            <div class="text-5xl mb-3">🌿</div>
            <h1 class="text-3xl font-black text-white">Try it — no signup needed</h1>
            <p class="text-white/70 mt-2">Set up in 10 seconds. Data stays on your device.</p>
        </div>
        <div class="bg-white rounded-3xl p-7 shadow-2xl space-y-5">
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">What are you quitting?</label>
                <div class="grid grid-cols-2 gap-2">
                    <button type="button" @click="setupAddiction='alcohol'"
                            :class="setupAddiction==='alcohol'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2.5 text-sm font-semibold transition">🍺 Alcohol</button>
                    <button type="button" @click="setupAddiction='smoking'"
                            :class="setupAddiction==='smoking'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2.5 text-sm font-semibold transition">🚬 Smoking</button>
                    <button type="button" @click="setupAddiction='cannabis'"
                            :class="setupAddiction==='cannabis'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2.5 text-sm font-semibold transition">🌿 Cannabis</button>
                    <button type="button" @click="setupAddiction='both'"
                            :class="setupAddiction==='both'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2.5 text-sm font-semibold transition">💪 Alcohol + Smoking</button>
                </div>
            </div>
            {# Date fields per track #}
            <div x-show="setupAddiction==='alcohol'||setupAddiction==='both'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Alcohol-free since</label>
                <input type="datetime-local" x-model="setupAlcoholDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <div x-show="setupAddiction==='smoking'||setupAddiction==='both'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Smoke-free since</label>
                <input type="datetime-local" x-model="setupSmokingDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <div x-show="setupAddiction==='cannabis'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Cannabis-free since</label>
                <input type="datetime-local" x-model="setupCannabisDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <p class="text-xs text-gray-400 -mt-3">Leave as today if you're just starting 🌱</p>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Daily spend <span class="font-normal normal-case text-gray-300">— optional, for money saved tracking</span></label>
                <div class="flex gap-2">
                    <select x-model="setupCurrency" class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 bg-white">
                        <option>$</option><option>€</option><option>£</option><option>¥</option><option>₹</option><option>A$</option><option>C$</option>
                    </select>
                    <input x-show="setupAddiction==='alcohol'||setupAddiction==='both'" type="number" x-model="setupAlcoholCost" min="0" step="0.5" placeholder="Alcohol /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                    <input x-show="setupAddiction==='smoking'||setupAddiction==='both'" type="number" x-model="setupSmokingCost" min="0" step="0.5" placeholder="Smoking /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                    <input x-show="setupAddiction==='cannabis'" type="number" x-model="setupCannabisCost" min="0" step="0.5" placeholder="Cannabis /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                </div>
            </div>
            <button @click="startDemo()" :disabled="!setupReady"
                    class="w-full py-3.5 bg-brand-600 hover:bg-brand-700 disabled:opacity-50 text-white rounded-2xl font-bold text-base transition">
                Start my journey →
            </button>
            <p class="text-center text-xs text-gray-400">No account. No email. Just you and your streak.</p>
        </div>
        <p class="text-center text-white/50 text-xs mt-5">
            Already have an account? <a href="/login" class="text-white/80 hover:text-white underline">Sign in</a>
        </p>
    </div>
</div>

{# ══ DEMO DASHBOARD ══ #}
<div x-show="ready" x-cloak class="pt-14">

    {# Always-visible preview banner #}
    <div class="bg-indigo-600 text-white px-4 py-3 text-center text-xs sm:text-sm">
        👋 <strong>Preview mode</strong> — features are limited &amp; data lives only on this device.
        <span class="hidden sm:inline text-indigo-200 mx-1">·</span>
        <span class="block sm:inline mt-0.5 sm:mt-0"><a :href="registerUrl" class="underline font-semibold">Sign up free</a> for full functionality, mood insights, AI coaching &amp; more →</span>
    </div>

    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10" style="contain:strict">
        <div class="absolute top-20 right-0 w-48 h-48 rounded-full bg-teal-100/40" style="animation:floatA 14s ease-in-out infinite"></div>
        <div class="absolute top-1/3 -left-10 w-56 h-56 rounded-full bg-indigo-100/30" style="animation:floatB 18s ease-in-out infinite"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-6">

        {# ── Streak hero — single addiction ── #}
        <div x-show="addiction !== 'both'" class="rounded-3xl p-7 mb-6 text-white relative overflow-hidden"
             :class="addiction==='smoking' ? 'bg-gradient-to-br from-violet-500 to-indigo-700' : (addiction==='cannabis' ? 'bg-gradient-to-br from-green-500 to-emerald-700' : 'bg-gradient-to-br from-teal-500 to-brand-700')">
            <div class="absolute -right-10 -top-10 w-48 h-48 rounded-full bg-white/5"></div>
            <div class="relative z-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
                <div>
                    <p class="text-white/70 text-sm font-medium mb-1" x-text="addictionLabel"></p>
                    <div class="flex items-end gap-3">
                        <span class="text-7xl font-black" x-text="days"></span>
                        <span class="text-3xl font-bold text-white/80 mb-2">days</span>
                    </div>
                    <p class="text-white/60 text-sm mt-1">Since <span x-text="primaryDateFormatted"></span></p>
                    <div class="mt-3 inline-flex items-center gap-2 bg-white/20 rounded-full px-4 py-1.5">
                        <span x-text="level>=5?'🔥':(level>=3?'⭐':'🌱')"></span>
                        <span class="font-bold text-sm">Level <span x-text="level"></span>: <span x-text="levelName"></span></span>
                    </div>
                    <p x-show="moneySaved > 0" class="text-white/80 text-sm font-semibold mt-2">💰 <span x-text="currency + moneySaved.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}) + ' saved'"></span></p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button @click="editOpen ? editOpen=false : openEdit()" class="px-4 py-2 bg-white/20 hover:bg-white/30 rounded-xl font-semibold text-sm transition">✏️ Edit</button>
                    <button @click="toggleSOS()" class="px-4 py-2 bg-red-500/80 hover:bg-red-500 rounded-xl font-semibold text-sm transition">🆘 SOS</button>
                    <button @click="deleteAll()" class="px-4 py-2 bg-black/20 hover:bg-black/30 rounded-xl font-semibold text-sm transition text-white/80">🗑️ Delete all data & start over</button>
                </div>
            </div>
        </div>

        {# ── Streak hero — both (alcohol + smoking) ── #}
        <div x-show="addiction === 'both'" class="mb-6">
            <div class="grid md:grid-cols-2 gap-4">
                <div class="bg-gradient-to-br from-teal-500 to-brand-700 rounded-3xl p-6 text-white relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/5"></div>
                    <div class="relative z-10">
                        <p class="text-white/70 text-sm font-medium mb-1">🍺 Alcohol-free</p>
                        <div class="flex items-end gap-2">
                            <span class="text-5xl font-black" x-text="alcoholDays"></span>
                            <span class="text-xl font-bold text-white/80 mb-1">days</span>
                        </div>
                        <p class="text-white/60 text-xs mt-1">Since <span x-text="alcoholDateFormatted"></span></p>
                    </div>
                </div>
                <div class="bg-gradient-to-br from-violet-500 to-indigo-700 rounded-3xl p-6 text-white relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-32 h-32 rounded-full bg-white/5"></div>
                    <div class="relative z-10">
                        <p class="text-white/70 text-sm font-medium mb-1">🚬 Smoke-free</p>
                        <div class="flex items-end gap-2">
                            <span class="text-5xl font-black" x-text="smokingDays"></span>
                            <span class="text-xl font-bold text-white/80 mb-1">days</span>
                        </div>
                        <p class="text-white/60 text-xs mt-1">Since <span x-text="smokingDateFormatted"></span></p>
                    </div>
                </div>
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-3">
                <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-lg px-3 py-1.5">
                    <span x-text="level>=5?'🔥':(level>=3?'⭐':'🌱')"></span>
                    <span class="text-amber-700 font-bold text-sm">Level <span x-text="level"></span>: <span x-text="levelName"></span></span>
                </div>
                <button @click="editOpen ? editOpen=false : openEdit()" class="px-4 py-2 bg-white hover:bg-gray-50 border border-gray-200 rounded-xl font-semibold text-sm transition text-gray-700">✏️ Edit</button>
                <button @click="toggleSOS()" class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-xl font-semibold text-sm transition">🆘 SOS</button>
                <button @click="deleteAll()" class="px-4 py-2 bg-white hover:bg-red-50 border border-red-200 text-red-500 rounded-xl font-semibold text-sm transition">🗑️ Delete all data & start over</button>
            </div>
        </div>

        {# ── Shared edit panel ── #}
        <div x-show="editOpen" x-cloak class="mb-6 bg-white rounded-2xl p-5 shadow-sm border border-gray-100 space-y-4">
            <p class="font-bold text-gray-800 text-sm">Edit your settings</p>
            <div>
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">What are you quitting?</p>
                <div class="grid grid-cols-2 gap-2">
                    <button type="button" @click="editAddiction='alcohol'"
                            :class="editAddiction==='alcohol'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2 text-sm font-semibold transition">🍺 Alcohol</button>
                    <button type="button" @click="editAddiction='smoking'"
                            :class="editAddiction==='smoking'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2 text-sm font-semibold transition">🚬 Smoking</button>
                    <button type="button" @click="editAddiction='cannabis'"
                            :class="editAddiction==='cannabis'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2 text-sm font-semibold transition">🌿 Cannabis</button>
                    <button type="button" @click="editAddiction='both'"
                            :class="editAddiction==='both'?'bg-brand-600 text-white border-brand-600':'bg-white text-gray-600 border-gray-200 hover:border-brand-400'"
                            class="border-2 rounded-xl py-2 text-sm font-semibold transition">💪 Alcohol + Smoking</button>
                </div>
            </div>
            <div x-show="editAddiction==='alcohol'||editAddiction==='both'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Alcohol-free since</label>
                <input type="datetime-local" x-model="editAlcoholDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <div x-show="editAddiction==='smoking'||editAddiction==='both'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Smoke-free since</label>
                <input type="datetime-local" x-model="editSmokingDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <div x-show="editAddiction==='cannabis'">
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Cannabis-free since</label>
                <input type="datetime-local" x-model="editCannabisDate" :max="today"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Daily spend <span class="font-normal normal-case text-gray-300">— for money saved tracking</span></label>
                <div class="flex gap-2">
                    <select x-model="editCurrency" class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 bg-white">
                        <option>$</option><option>€</option><option>£</option><option>¥</option><option>₹</option><option>A$</option><option>C$</option>
                    </select>
                    <input x-show="editAddiction==='alcohol'||editAddiction==='both'" type="number" x-model="editAlcoholCost" min="0" step="0.5" placeholder="Alcohol /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                    <input x-show="editAddiction==='smoking'||editAddiction==='both'" type="number" x-model="editSmokingCost" min="0" step="0.5" placeholder="Smoking /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                    <input x-show="editAddiction==='cannabis'" type="number" x-model="editCannabisCost" min="0" step="0.5" placeholder="Cannabis /day"
                           class="flex-1 px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                </div>
            </div>
            <div class="flex gap-2 pt-1">
                <button @click="saveEdit()" class="flex-1 py-2 bg-brand-600 hover:bg-brand-700 text-white rounded-xl font-bold text-sm transition">Save changes</button>
                <button @click="editOpen=false" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 rounded-xl text-sm font-semibold transition">Cancel</button>
            </div>
        </div>

        {# SOS — inline, right below streak #}
        <div x-show="sosOpen" x-cloak id="demo-sos-block" class="mb-6 max-w-xl mx-auto bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 rounded-2xl p-5 text-white">
            <div class="text-center mb-4">
                <div class="text-3xl mb-1">🌊</div>
                <h3 class="text-lg font-black">You're Having a Craving</h3>
                <p class="text-white/60 text-xs mt-1">Cravings peak in 15-20 min. They always pass.</p>
            </div>
            <div x-data="{ tab: 'breathe' }">
                <div class="flex flex-wrap justify-center gap-1.5 mb-4">
                    <button @click="tab='breathe'" :class="tab==='breathe'?'bg-teal-500 text-white':'bg-white/10 text-white/70 hover:bg-white/20'"
                            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition">🫁 Breathing</button>
                    <button @click="tab='ground'" :class="tab==='ground'?'bg-teal-500 text-white':'bg-white/10 text-white/70 hover:bg-white/20'"
                            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition">👁️ Grounding</button>
                    <button @click="tab='cold'" :class="tab==='cold'?'bg-teal-500 text-white':'bg-white/10 text-white/70 hover:bg-white/20'"
                            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition">❄️ Cold Water</button>
                    <button @click="tab='move'" :class="tab==='move'?'bg-teal-500 text-white':'bg-white/10 text-white/70 hover:bg-white/20'"
                            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition">🚶 Move</button>
                    <button @click="tab='urge'" :class="tab==='urge'?'bg-teal-500 text-white':'bg-white/10 text-white/70 hover:bg-white/20'"
                            class="flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold transition">🌊 Urge Surf</button>
                </div>

                {# Breathing #}
                <div x-show="tab==='breathe'" x-data="breathingExercise()" class="text-center">
                    <p class="text-white/60 text-xs mb-3">4-7-8 Breathing — activates your parasympathetic nervous system</p>
                    <div class="flex items-center justify-center mb-4">
                        <div class="w-28 h-28 rounded-full bg-teal-500/30 flex items-center justify-center breathe-scale"
                             :style="{transform:`scale(${breatheScale})`,opacity:breatheOpacity}">
                            <div class="w-16 h-16 rounded-full bg-teal-400/50 flex items-center justify-center">
                                <span class="text-white font-bold text-xl" x-text="breatheCount"></span>
                            </div>
                        </div>
                    </div>
                    <p class="text-white font-semibold" x-text="breathePhase"></p>
                    <button @click="toggleBreathing()"
                            class="mt-4 px-6 py-2 bg-teal-500 hover:bg-teal-600 text-white rounded-xl font-semibold transition text-sm"
                            x-text="breathing?'Pause':'Start'"></button>
                </div>

                {# Grounding #}
                <div x-show="tab==='ground'" x-data="{step:0}" class="text-center">
                    <p class="text-white/60 text-xs mb-4">5-4-3-2-1 Grounding — pulls you into the present moment</p>
                    <template x-if="step<5">
                        <div>
                            <template x-for="(s,i) in [{n:5,q:'Name 5 things you can SEE'},{n:4,q:'Name 4 things you can HEAR'},{n:3,q:'Name 3 things you can TOUCH'},{n:2,q:'Name 2 things you can SMELL'},{n:1,q:'Name 1 thing you can TASTE'}]" :key="i">
                                <div x-show="step===i" class="bg-white/10 rounded-xl p-4 mb-3">
                                    <p class="text-teal-300 font-black text-3xl" x-text="s.n"></p>
                                    <p class="text-white font-semibold mt-1 text-sm" x-text="s.q"></p>
                                </div>
                            </template>
                            <button @click="step<4?step++:step=5" class="px-6 py-2 bg-teal-500 hover:bg-teal-600 text-white rounded-xl font-semibold text-sm transition">Next →</button>
                        </div>
                    </template>
                    <template x-if="step>=5">
                        <div>
                            <p class="text-teal-300 font-bold text-lg">You're grounded. 🌿</p>
                            <p class="text-white/50 text-sm mt-1">Notice how the intensity has shifted.</p>
                            <button @click="step=0" class="mt-3 text-xs text-white/50 hover:text-white">Start again</button>
                        </div>
                    </template>
                </div>

                {# Cold Water #}
                <div x-show="tab==='cold'" class="text-white">
                    <p class="text-white/60 text-xs mb-4 text-center">Cold activates your dive reflex — instantly calms the nervous system</p>
                    <div class="space-y-3">
                        <div class="bg-white/10 rounded-xl p-4">
