<!DOCTYPE html>
<html lang="en" class="h-full overflow-x-hidden">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0d9488">
    <title>{% block title %}TheDayAfter{% endblock %} — Reclaim Your Life</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50:  '#f0fdf9',
                            100: '#ccfbef',
                            200: '#99f6e0',
                            300: '#5eead4',
                            400: '#2dd4bf',
                            500: '#14b8a6',
                            600: '#0d9488',
                            700: '#0f766e',
                            800: '#115e59',
                            900: '#134e4a',
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'bounce-slow': 'bounce 2s infinite',
                    }
                }
            }
        }
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {% if ga_tracking_id %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga_tracking_id }}"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '{{ ga_tracking_id }}');
    </script>
    {% endif %}
    <style>
        [x-cloak] { display: none !important; }
        .gradient-hero {
            background: linear-gradient(135deg, #0f766e 0%, #1d4ed8 50%, #7c3aed 100%);
        }
        .card-glow {
            box-shadow: 0 0 30px rgba(20, 184, 166, 0.15);
        }
        .xp-bar {
            background: linear-gradient(90deg, #14b8a6, #6366f1);
            transition: width 1s ease-in-out;
        }
        .streak-number {
            background: linear-gradient(135deg, #f59e0b, #ef4444);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        @keyframes countUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .count-up { animation: countUp 0.6s ease-out forwards; }
        .breathe-circle {
            animation: breathe 4s ease-in-out infinite;
        }
        @keyframes breathe {
            0%, 100% { transform: scale(1); opacity: 0.7; }
            50% { transform: scale(1.3); opacity: 1; }
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body class="h-full bg-gray-50 text-gray-900 overflow-x-hidden">

{# Flash messages #}
{% if app.flashes|length %}
<div class="fixed top-4 right-4 z-50 space-y-2" x-data="{ messages: [] }" x-init="
    {% for type, msgs in app.flashes %}
        {% for msg in msgs %}
        setTimeout(() => { messages.push({ type: '{{ type }}', text: {{ msg|json_encode|raw }}, id: Date.now() + Math.random() }) }, 100);
        {% endfor %}
    {% endfor %}
" @achievement-earned.window="messages.push({ type: 'achievement', text: $event.detail, id: Date.now() })">
    <template x-for="m in messages" :key="m.id">
        <div x-show="true" x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 translate-x-4"
             x-transition:enter-end="opacity-100 translate-x-0"
             x-init="setTimeout(() => messages = messages.filter(x => x.id !== m.id), 5000)"
             :class="{
                'bg-emerald-600': m.type === 'success',
                'bg-yellow-500': m.type === 'achievement',
                'bg-blue-600': m.type === 'info',
                'bg-red-600': m.type === 'error'
             }"
             class="text-white px-5 py-3 rounded-xl shadow-lg max-w-sm text-sm font-medium flex items-center gap-2">
            <span x-text="m.type === 'achievement' ? '🏆' : (m.type === 'success' ? '✓' : (m.type === 'error' ? '✕' : 'ℹ'))"></span>
            <span x-text="m.text"></span>
        </div>
    </template>
</div>
{% endif %}

{% if app.user %}
{# Authenticated nav #}
<nav class="bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
        <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2 text-brand-700 font-bold text-xl">
            <span class="text-2xl">🌿</span> TheDayAfter
        </a>
        <div class="hidden md:flex items-center gap-1">
            <a href="{{ path('app_dashboard') }}"    class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_dashboard' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">Dashboard</a>
            <a href="{{ path('app_checkin') }}"      class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_checkin' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">Check-In</a>
            <a href="{{ path('app_journal') }}"      class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_journal' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">Journal</a>
            <a href="{{ path('app_achievements') }}" class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_achievements' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">Achievements</a>
            <a href="{{ path('app_forum') }}"        class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_forum' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">Community</a>
            <a href="{{ path('app_settings') }}"     class="px-3 py-2 rounded-lg text-sm font-medium hover:bg-gray-100 {{ app.request.get('_route') starts with 'app_settings' ? 'bg-brand-50 text-brand-700' : 'text-gray-600' }}">⚙️</a>
            <a href="{{ path('app_craving') }}" class="ml-2 px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-semibold transition">🆘 SOS</a>
        </div>
        <div class="flex items-center gap-3">
            <div class="hidden sm:flex items-center gap-1 bg-amber-50 border border-amber-200 rounded-lg px-3 py-1.5">
                <span class="text-amber-500 text-sm">⚡</span>
                <span class="text-amber-700 font-bold text-sm">{{ app.user.totalXp }} XP</span>
            </div>
            <div x-data="{ open: false }" class="relative">
                <button @click="open = !open" class="flex items-center gap-2 text-sm text-gray-700 hover:text-gray-900">
                    <div class="w-8 h-8 rounded-full bg-brand-600 text-white flex items-center justify-center font-bold text-sm">
                        {{ app.user.name|first|upper }}
                    </div>
                </button>
                <div x-show="open" x-cloak @click.outside="open = false"
                     class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 py-1">
                    <div class="px-4 py-2 border-b border-gray-100">
                        <div class="font-medium text-gray-900">{{ app.user.name }}</div>
                        <div class="text-xs text-gray-500">{{ app.user.levelName }}</div>
                    </div>
                    <a href="{{ path('app_settings') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">⚙️ Settings</a>
                    <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50">Sign out</a>
                </div>
            </div>
        </div>
    </div>
</nav>

{# Mobile bottom nav + drawer #}
{% set route = app.request.get('_route') %}
<div class="md:hidden" x-data="{ drawerOpen: false }">

    {# Backdrop #}
    <div x-show="drawerOpen" x-cloak
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="drawerOpen = false"
         class="fixed inset-0 bg-black/40 z-40"></div>

    {# Slide-up drawer #}
    <div x-show="drawerOpen" x-cloak
         x-transition:enter="transition ease-out duration-250"
         x-transition:enter-start="opacity-0 translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-4"
         class="fixed bottom-20 left-3 right-3 z-50 bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden">

        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <span class="text-sm font-bold text-gray-700">Menu</span>
            <button @click="drawerOpen = false" class="text-gray-400 hover:text-gray-600 text-lg leading-none">✕</button>
        </div>

        <div class="grid grid-cols-2 gap-px bg-gray-100">
            {% set items = [
{route: 'app_journal',     icon: '📝', label: 'Journal'},
                {route: 'app_achievements',icon: '🏆', label: 'Achievements'},
                {route: 'app_mood_history', icon: '💭', label: 'Mood History'},
                {route: 'app_relapse',      icon: '🔄', label: 'Had a Setback'},
                {route: 'app_settings',    icon: '⚙️', label: 'Settings'},
            ] %}
            {% for item in items %}
            <a href="{{ path(item.route) }}"
               class="flex items-center gap-3 px-4 py-3.5 bg-white hover:bg-gray-50 transition
                      {{ route starts with item.route ? 'text-brand-700 font-semibold' : 'text-gray-700' }}">
                <span class="text-lg">{{ item.icon }}</span>
                <span class="text-sm font-medium">{{ item.label }}</span>
            </a>
            {% endfor %}
            <a href="{{ path('app_logout') }}"
               class="flex items-center gap-3 px-4 py-3.5 bg-white hover:bg-gray-50 transition text-gray-400">
                <span class="text-lg">🚪</span>
                <span class="text-sm font-medium">Sign out</span>
            </a>
        </div>
    </div>

    {# Bottom bar: Home · SOS · Community · ☰ #}
    <nav class="fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 shadow-lg">
        <div class="flex items-center justify-around px-2 py-1 pb-safe">
            <a href="{{ path('app_dashboard') }}"
               class="flex flex-col items-center gap-0.5 px-3 py-2 rounded-xl transition {{ route starts with 'app_dashboard' ? 'text-brand-600' : 'text-gray-400' }}">
                <span class="text-xl">🏠</span>
                <span class="text-[10px] font-medium">Home</span>
            </a>
            <a href="{{ path('app_checkin') }}"
               class="flex flex-col items-center gap-0.5 px-3 py-2 rounded-xl transition {{ route starts with 'app_checkin' ? 'text-brand-600' : 'text-gray-400' }}">
                <span class="text-xl">📊</span>
                <span class="text-[10px] font-medium">Check-In</span>
            </a>
            <a href="{{ path('app_craving') }}"
               class="flex flex-col items-center gap-0.5 -mt-4 px-4 py-2 bg-red-500 text-white rounded-2xl shadow-lg shadow-red-200">
                <span class="text-xl">🆘</span>
                <span class="text-[10px] font-bold">SOS</span>
            </a>
            <a href="{{ path('app_forum') }}"
               class="flex flex-col items-center gap-0.5 px-3 py-2 rounded-xl transition {{ route starts with 'app_forum' ? 'text-brand-600' : 'text-gray-400' }}">
                <span class="text-xl">🤝</span>
                <span class="text-[10px] font-medium">Community</span>
            </a>
            <button @click="drawerOpen = !drawerOpen"
                    class="flex flex-col items-center gap-0.5 px-3 py-2 rounded-xl transition"
                    :class="drawerOpen ? 'text-brand-600' : 'text-gray-400'">
                <span class="text-xl">☰</span>
                <span class="text-[10px] font-medium">More</span>
            </button>
        </div>
    </nav>
</div>
{% else %}
{# Public nav #}
<nav id="public-nav" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
        <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-white font-bold text-xl">
            <span class="text-2xl">🌿</span> TheDayAfter
        </a>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_login') }}"    class="text-white/90 hover:text-white text-sm font-medium">Sign in</a>
            <a href="{{ path('app_register') }}" class="px-4 py-2 bg-white text-brand-700 rounded-lg text-sm font-semibold hover:bg-brand-50 transition">Get Started Free</a>
        </div>
    </div>
</nav>
{% endif %}

<main>
    {% block body %}{% endblock %}
</main>

{% if app.user %}
<footer class="bg-white border-t border-gray-200 mt-2 py-5 pb-24 md:pb-5 text-center text-sm text-gray-500">
    <p class="font-medium">TheDayAfter — You are stronger than you think. 💚</p>
    <p class="mt-2 flex items-center justify-center gap-3 flex-wrap">
        <a href="https://github.com/thedayafterapp/thedayafter" target="_blank" rel="noopener"
           class="hover:text-gray-800 transition">⭐ Open source on GitHub (MIT License)</a>
        <span class="text-gray-300">·</span>
        <span>Free forever</span>
        <span class="text-gray-300">·</span>
        <a href="mailto:thedayafterapp@gmail.com" class="hover:text-gray-800 transition">Contact</a>
    </p>
</footer>
{% endif %}

{% block scripts %}{% endblock %}

<script>
document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
        var id = a.getAttribute('href').slice(1);
        var target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        var container = document.body;
        var start = container.scrollTop;
        var end = target.getBoundingClientRect().top + start - 64;
        var duration = 600;
        var startTime = null;
        function ease(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }
        function step(now) {
            if (!startTime) startTime = now;
            var p = Math.min((now - startTime) / duration, 1);
            container.scrollTop = start + (end - start) * ease(p);
            if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    });
});
</script>

</body>
</html>
